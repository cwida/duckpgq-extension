# name: test/sql/generated_sql_quoting.test
# description: Generated SQL should correctly quote backing table and column names
# group: [sql]

require duckpgq

statement ok
CREATE TABLE "select"("from" BIGINT, "Name Value" VARCHAR);

statement ok
INSERT INTO "select" VALUES
    (1, 'Alice'),
    (2, 'Bob'),
    (3, 'Carol');

statement ok
CREATE TABLE "group"("source key" BIGINT, "destination key" BIGINT);

statement ok
INSERT INTO "group" VALUES
    (1, 2),
    (1, 3),
    (2, 3);

statement ok
CREATE PROPERTY GRAPH pg_quoted
VERTEX TABLES (
    "select" PROPERTIES ("from", "Name Value") LABEL person
)
EDGE TABLES (
    "group" SOURCE KEY ("source key") REFERENCES "select" ("from")
            DESTINATION KEY ("destination key") REFERENCES "select" ("from")
            LABEL knows
);

query TIIIII
SELECT table_name, is_vertex_table::INTEGER, COALESCE(vertex_count, -1), COALESCE(edge_count, -1),
       COALESCE(unique_source_count, -1), COALESCE(isolated_sources, -1)
FROM summarize_property_graph(pg_quoted)
ORDER BY table_name;
----
group	0	-1	3	2	1
select	1	3	-1	-1	-1

query I
SELECT count(*) FROM pagerank(pg_quoted, person, knows);
----
3

query IT
SELECT gt.src_id, gt.dst_name
FROM GRAPH_TABLE (pg_quoted
    MATCH (a:person)-[k:knows]->(b:person)
    COLUMNS (a."from" AS src_id, b."Name Value" AS dst_name)
) gt
ORDER BY gt.src_id, gt.dst_name;
----
1	Bob
1	Carol
2	Carol
