# name: test/sql/path_finding/bounded_path_expansion.test
# description: Bounded non-shortest path expansion should not use CSR reachability
# group: [path_finding]

require duckpgq

statement ok
CREATE TABLE nodes(id BIGINT);

statement ok
CREATE TABLE edges(src BIGINT, dst BIGINT);

statement ok
INSERT INTO nodes VALUES (0), (1), (2), (3), (4);

statement ok
INSERT INTO edges VALUES (0, 1), (0, 2), (0, 3), (1, 3), (2, 3), (3, 4);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    nodes LABEL N
)
EDGE TABLES (
    edges SOURCE KEY (src) REFERENCES nodes (id)
          DESTINATION KEY (dst) REFERENCES nodes (id)
          LABEL E
);

query II
-SELECT b_id, count(*) AS path_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,2}(b:N)
    COLUMNS (b.id AS b_id)
) q
GROUP BY b_id
ORDER BY b_id;
----
1	1
2	1
3	1
4	1

query I
-SELECT count(*) AS path_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
) q;
----
4

query II
-SELECT b_id, count(*) AS path_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{0,2}(b:N)
    COLUMNS (b.id AS b_id)
) q
GROUP BY b_id
ORDER BY b_id;
----
0	1
1	1
2	1
3	1
4	1

query I
-SELECT count(*) AS path_count
FROM (
    FROM GRAPH_TABLE (pg
        MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
        COLUMNS (b.id AS b_id)
    )
    UNION ALL
    FROM GRAPH_TABLE (pg
        MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
        COLUMNS (b.id AS b_id)
    )
) q;
----
8

query I
-WITH reached AS (
    FROM GRAPH_TABLE (pg
        MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
        COLUMNS (b.id AS b_id)
    )
),
direct_edges AS (
    FROM GRAPH_TABLE (pg
        MATCH (x:N)-[e:E]->(y:N)
        COLUMNS (x.id AS x_id, y.id AS y_id)
    )
)
SELECT count(*) AS join_count
FROM reached
JOIN direct_edges ON reached.b_id = direct_edges.x_id;
----
3

query I
-SELECT count(*) AS join_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
) reached
JOIN GRAPH_TABLE (pg
    MATCH (x:N)-[e:E]->(y:N)
    COLUMNS (x.id AS x_id, y.id AS y_id)
) direct_edges ON reached.b_id = direct_edges.x_id;
----
3

statement ok
CREATE TABLE reached_nodes(id BIGINT);

statement ok
-INSERT INTO reached_nodes
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
);

query I
SELECT count(*) FROM reached_nodes;
----
4
