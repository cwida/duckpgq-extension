# name: test/sql/query_table_function.test
# description: Test DuckPGQ with query() table function (issue #210)
# group: [duckpgq]

require duckpgq

# Setup
statement ok
CREATE TABLE Person(id BIGINT, name VARCHAR);

statement ok
INSERT INTO Person VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
CREATE TABLE knows(src BIGINT, dst BIGINT);

statement ok
INSERT INTO knows VALUES (1, 2), (2, 3), (1, 3);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (Person)
EDGE TABLES (knows SOURCE KEY (src) REFERENCES Person (id)
                   DESTINATION KEY (dst) REFERENCES Person (id));

# Test 1: Basic query() with GRAPH_TABLE (no - prefix inside query())
query II
FROM query('FROM GRAPH_TABLE (pg MATCH (a:Person) COLUMNS (a.id, a.name)) tmp LIMIT 2');
----
1	Alice
2	Bob

# Test 2: query() with path pattern
query II
FROM query('FROM GRAPH_TABLE (pg MATCH (a:Person)-[k:knows]->(b:Person) COLUMNS (a.name as src, b.name as dst)) tmp');
----
Alice	Carol
Bob	Carol
Alice	Bob

# Test 3: Direct GRAPH_TABLE query still works
query II
-FROM GRAPH_TABLE (pg
    MATCH (a:Person)
    COLUMNS (a.id, a.name)
) tmp
LIMIT 2;
----
1	Alice
2	Bob
