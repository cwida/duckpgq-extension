# name: test/sql/prepared_statements.test
# description: Test prepared statements with DuckPGQ (issue #75)
# group: [duckpgq]

require duckpgq

# Setup graph
statement ok
CREATE TABLE Person(id BIGINT, name VARCHAR);

statement ok
INSERT INTO Person VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
CREATE TABLE knows(src BIGINT, dst BIGINT);

statement ok
INSERT INTO knows VALUES (1, 2), (2, 3), (1, 3);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (Person)
EDGE TABLES (knows SOURCE KEY (src) REFERENCES Person (id)
                   DESTINATION KEY (dst) REFERENCES Person (id));

# Test 1: Basic PREPARE (note: - prefix must be at start of whole command)
statement ok
-PREPARE basic_query AS
FROM GRAPH_TABLE (pg
    MATCH (a:Person)
    COLUMNS (a.id, a.name)
) tmp;

# Test 2: EXECUTE basic query
query II
EXECUTE basic_query;
----
1	Alice
2	Bob
3	Carol

# Test 3: PREPARE with path finding
statement ok
-PREPARE path_query AS
FROM GRAPH_TABLE (pg
    MATCH (a:Person)-[k:knows]->(b:Person)
    COLUMNS (a.name as src, b.name as dst)
) tmp;

# Test 4: EXECUTE path query
query II
EXECUTE path_query;
----
Alice	Carol
Bob	Carol
Alice	Bob

# Test 5: DEALLOCATE
statement ok
DEALLOCATE basic_query;

statement ok
DEALLOCATE path_query;
