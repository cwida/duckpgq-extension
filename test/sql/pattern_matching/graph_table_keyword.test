# name: test/sql/pattern_matching/graph_table_keyword.test
# description: Testing GRAPH_TABLE and GRAPH TABLE spelling
# group: [pattern_matching]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'Daniel'), (1, 'Tavneet');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT);INSERT INTO know VALUES (0, 1);

statement ok
CREATE PROPERTY GRAPH pg
VERTEX TABLES (Student PROPERTIES (id, name) LABEL Person)
EDGE TABLES (
    know SOURCE KEY (src) REFERENCES Student (id)
         DESTINATION KEY (dst) REFERENCES Student (id)
         LABEL Knows
);

query I
SELECT id FROM GRAPH TABLE (pg MATCH (Person) COLUMNS (Person.id as id)) ORDER BY id;
----
0
1

query I
SELECT id FROM GRAPH_TABLE (pg MATCH (Person) COLUMNS (Person.id as id)) ORDER BY id;
----
0
1

query II
SELECT person, friend
FROM GRAPH_TABLE (
    pg MATCH (p:Person)-[k:Knows]->(q:Person)
    COLUMNS (p.name AS person, q.name AS friend)
)
ORDER BY person, friend;
----
Daniel	Tavneet

query II
SELECT person, friend
FROM GRAPH_TABLE (
    pg MATCH (q:Person)<-[k:Knows]-(p:Person)
    COLUMNS (p.name AS person, q.name AS friend)
)
ORDER BY person, friend;
----
Daniel	Tavneet
